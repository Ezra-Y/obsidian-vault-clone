{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "module": "Node16",
    "moduleResolution": "Node16",
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2020",
    "types": [
      "node"
    ]
  },
  "include": [
    "**/*.ts"
  ]
}
